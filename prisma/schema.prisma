generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum BusinessType {
  TRUCKLOAD
  BROKERAGE
}

enum AnalysisStatus {
  DRAFT
  ASSESSMENT
  REVIEW
  COMPLETE
}

enum AnalysisModuleStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETE
}

enum NarrativeMode {
  TEMPLATE
  CUSTOM
}

enum PresentationGenerationStatus {
  PENDING
  GENERATING
  COMPLETE
  FAILED
}

model Analysis {
  id               String         @id @default(cuid())
  companyName      String
  customerContact  String?
  businessType     BusinessType
  preparedBy       String
  analysisDate     DateTime
  customerLogoPath String?
  status           AnalysisStatus @default(DRAFT)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  modules          AnalysisModule[]
  presentationGenerations PresentationGeneration[]
}

model AnalysisModule {
  id              String               @id @default(cuid())
  analysisId      String
  analysis        Analysis             @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  moduleKey       String
  status          AnalysisModuleStatus @default(NOT_STARTED)
  displayOrder    Int
  narrativeMode   NarrativeMode        @default(TEMPLATE)
  customNarrative String?
  customNarrativeSourceFingerprint String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  inputs          AnalysisModuleInput[]

  @@unique([analysisId, moduleKey])
  @@index([analysisId, displayOrder])
}

model AnalysisModuleInput {
  id               String         @id @default(cuid())
  analysisModuleId String
  analysisModule   AnalysisModule @relation(fields: [analysisModuleId], references: [id], onDelete: Cascade)
  inputKey         String
  numericValue     Float
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([analysisModuleId, inputKey])
}


model PresentationGeneration {
  id              String   @id @default(cuid())
  analysisId      String
  analysis        Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  templateVersion String
  snapshotJson    String
  filePath        String?
  status          PresentationGenerationStatus @default(PENDING)
  generatedAt     DateTime @default(now())

  @@index([analysisId, generatedAt])
}
