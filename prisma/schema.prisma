generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum BusinessType {
  TRUCKLOAD
  BROKERAGE
}

enum AnalysisStatus {
  DRAFT
  ASSESSMENT
  REVIEW
  COMPLETE
}

enum AnalysisModuleStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETE
}

enum NarrativeMode {
  TEMPLATE
  CUSTOM
}

enum PresentationGenerationStatus {
  PENDING
  GENERATING
  COMPLETE
  FAILED
}

enum OverlapDisposition {
  ASSUMPTIONS_MUTUALLY_EXCLUSIVE
  VALUES_ADJUSTED_TO_REMOVE_OVERLAP
  EXCLUDE_FROM_TOTALS
  NEEDS_REVISION
}

enum CustomOpportunityStatus {
  DRAFT
  COMPLETE
  NEEDS_REVISION
  RETIRED
}

model Analysis {
  id               String         @id @default(cuid())
  companyName      String
  customerContact  String?
  businessType     BusinessType
  preparedBy       String
  analysisDate     DateTime
  customerLogoPath String?
  status           AnalysisStatus @default(DRAFT)
  investmentOneTimeCost           Float?
  investmentAnnualRecurringCost   Float?
  investmentChangeManagementCost  Float?
  roiHorizonYears                 Int?
  roiDiscountRatePct              Float?
  adoptionSchedulePctJson         String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  modules          AnalysisModule[]
  presentationGenerations PresentationGeneration[]
  overlapDispositions AnalysisOverlapDisposition[]
  customOpportunities CustomOpportunity[]
}

model CustomOpportunity {
  id              String   @id @default(cuid())
  analysisId      String
  analysis        Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  title           String
  shortTitle      String?
  categoryKey     String
  valueClassification String
  valueFrequency  String
  enteredValue    Float
  monthlyRecurringValue Float?
  annualRecurringValue Float?
  annualOnlyValue Float?
  informationalCapitalValue Float?
  calculationRationale String
  howMcLeodHelps String?
  customerBusinessImpact String?
  presentationCallout String?
  methodologyNote String?
  sourceNote String?
  status CustomOpportunityStatus @default(DRAFT)
  version Int @default(1)
  sourceFingerprint String
  displayOrder Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  assumptions CustomOpportunityAssumption[]

  @@index([analysisId, displayOrder])
}

model CustomOpportunityAssumption {
  id String @id @default(cuid())
  customOpportunityId String
  customOpportunity CustomOpportunity @relation(fields: [customOpportunityId], references: [id], onDelete: Cascade)
  label String
  displayValue String
  numericValue Float?
  unit String?
  sourceNote String?
  displayOrder Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customOpportunityId, displayOrder])
}

model AnalysisModule {
  id              String               @id @default(cuid())
  analysisId      String
  analysis        Analysis             @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  moduleKey       String
  status          AnalysisModuleStatus @default(NOT_STARTED)
  displayOrder    Int
  narrativeMode   NarrativeMode        @default(TEMPLATE)
  customNarrative String?
  customNarrativeSourceFingerprint String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  inputs          AnalysisModuleInput[]

  @@unique([analysisId, moduleKey])
  @@index([analysisId, displayOrder])
}

model AnalysisModuleInput {
  id               String         @id @default(cuid())
  analysisModuleId String
  analysisModule   AnalysisModule @relation(fields: [analysisModuleId], references: [id], onDelete: Cascade)
  inputKey         String
  numericValue     Float
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([analysisModuleId, inputKey])
}


model AnalysisOverlapDisposition {
  id                  String             @id @default(cuid())
  analysisId          String
  analysis            Analysis           @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  overlapGroupKey     String
  disposition         OverlapDisposition
  acknowledgmentText  String?
  sourceFingerprint   String
  excludedModuleKeysJson String?
  reviewedAt          DateTime
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@unique([analysisId, overlapGroupKey])
  @@index([analysisId])
}

model PresentationGeneration {
  id              String   @id @default(cuid())
  analysisId      String
  analysis        Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  templateVersion String
  snapshotJson    String
  filePath        String?
  status          PresentationGenerationStatus @default(PENDING)
  generatedAt     DateTime @default(now())

  @@index([analysisId, generatedAt])
}
